:root{--bg:#ffffff;--bg2:#f7f7f7;--border:#e8e8e8;--text:#111111;--text2:#555555;--text3:#999999;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;font-size:14px;line-height:1.6;}
nav{display:flex;justify-content:space-between;align-items:center;padding:14px 24px;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:100;}
.nav-logo{font-weight:600;font-size:15px;color:var(--text);display:flex;align-items:center;gap:8px;text-decoration:none;}
.logo-mark{width:22px;height:22px;background:var(--text);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.logo-mark svg{width:10px;height:10px;}
.nav-links{display:flex;gap:20px;}
.nav-links a{color:var(--text3);text-decoration:none;font-size:13px;}
.nav-links a:hover{color:var(--text);}
.coffee-btn{border:1px solid var(--border);color:var(--text);padding:6px 14px;border-radius:6px;font-size:12px;text-decoration:none;background:var(--bg);white-space:nowrap;}
.coffee-btn:hover{background:var(--bg2);}
@media(max-width:600px){.nav-links{display:none;}}

.page-wrap{max-width:760px;margin:0 auto;padding:48px 24px;}
.page-title{font-size:32px;font-weight:600;color:var(--text);margin-bottom:8px;}
.page-sub{font-size:15px;color:var(--text2);margin-bottom:48px;}

.steps{display:grid;grid-template-columns:1fr 1fr;gap:32px;}
@media(max-width:600px){.steps{grid-template-columns:1fr;}}
.step{}
.step-num{font-size:40px;font-weight:600;color:var(--bg3,#e8e8e8);line-height:1;margin-bottom:10px;color:#ebebeb;}
.step h3{font-size:15px;font-weight:600;color:var(--text);margin-bottom:6px;}
.step p{font-size:13px;color:var(--text2);line-height:1.7;}

.ad-unit{background:var(--bg2);border:1px dashed var(--border);border-radius:8px;padding:12px;text-align:center;margin:48px 0;min-height:90px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;}
.ad-label{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;}

.cta-box{background:var(--bg2);border-radius:10px;padding:28px;text-align:center;margin-top:48px;}
.cta-box h3{font-size:18px;font-weight:600;margin-bottom:8px;}
.cta-box p{font-size:13px;color:var(--text2);margin-bottom:20px;}
.cta-btn{display:inline-block;background:var(--text);color:white;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:500;text-decoration:none;}
.cta-btn:hover{background:#333;}

footer{border-top:1px solid var(--border);padding:18px 24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-top:64px;}
.footer-left{font-size:12px;color:var(--text3);}
.footer-right{display:flex;gap:14px;}
.footer-right a{font-size:12px;color:var(--text3);text-decoration:none;}
.footer-right a:hover{color:var(--text);}
</style>
